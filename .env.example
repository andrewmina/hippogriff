# =============================================================================
# Hippogriff — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- Azure ---
ARM_SUBSCRIPTION_ID=22b4d1c7-c874-42cf-b4a9-ab37b5a2f64f
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# --- Datadog ---
DD_API_KEY=your_dd_api_key_here
DD_APP_KEY=your_dd_app_key_here
DD_SITE=datadoghq.com

# --- Anthropic (tip-assistant service) ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Application ---
ENVIRONMENT=dev
CLUSTER_NAME=hippogriff-dev
AZURE_REGION=eastus
RESOURCE_GROUP=hippogriff-dev-rg
ACR_NAME=hippogriffacr
